---
import data from '../projects/projects.json'
const currentYear = new Date().getFullYear()
const age = Math.floor(currentYear - 2012.369);
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>samhith's corner</title>
    <style>
      :root {
        --accent: #ffd700;
        --glass: rgba(255, 255, 255, 0.08);
        --glass-border: rgba(255, 255, 255, 0.15);
      }

      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        margin: 0;
        padding: 0;
        background: linear-gradient(-45deg, #0f172a, #1e293b, #1e3c72, #0f172a);
        background-size: 400% 400%;
        animation: gradientBG 15s ease infinite;
        color: #f8fafc;
        line-height: 1.6;
      }

      @keyframes gradientBG {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
      }

      header {
        padding: 5rem 2rem 1rem; /* Reduced bottom padding */
        text-align: center;
      }

      h1 {
        font-size: clamp(2.5rem, 8vw, 4rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 0.5rem;
        background: linear-gradient(to right, #fff, #94a3b8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      header p {
        font-size: 1.1rem;
        color: #94a3b8;
        margin: 0;
      }

      h2 {
        font-size: 1.8rem;
        margin-bottom: 1.5rem;
        margin-top: 0rem;
        font-weight: 700;
      }

      /* Sections - Reduced margins from 4rem to 1.5rem */
      .section-content {
        max-width: 800px;
        margin: 1.5rem auto; 
        padding: 1.5rem 2rem;
        background: var(--glass);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        text-align: center;
        backdrop-filter: blur(12px);
      }

      /* Carousel Section */
      .carousel-container {
        padding: 2rem 0; /* Tightened padding */
      }

      .carousel {
        overflow: hidden;
        width: 100%;
        position: relative;
        mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
      }

      .carousel-inner {
        display: flex;
        gap: 1.2rem;
        padding: 1.5rem 0;
        width: max-content;
        animation: scroll 30s linear infinite;
      }

      @keyframes scroll {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
      }

      .carousel-inner:hover {
        animation-play-state: paused;
      }

      .card {
        flex: 0 0 280px;
        background: var(--glass);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        padding: 1.25rem;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        text-align: left;
      }

      .card:hover {
        transform: translateY(-5px);
        border-color: var(--accent);
        background: rgba(255, 255, 255, 0.12);
      }

      .card h3 {
        margin: 0 0 0.5rem;
        font-size: 1.2rem;
      }

      .card p {
        font-size: 0.9rem;
        color: #94a3b8;
        margin-bottom: 1rem;
      }

      .tech-stack {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
      }

      .tech-tag {
        font-size: 0.65rem;
        text-transform: uppercase;
        background: rgba(255, 255, 255, 0.1);
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
      }

      a {
        color: var(--accent);
        text-decoration: none;
        transition: 0.2s;
      }

      a:hover {
        filter: brightness(1.2);
        text-decoration: underline;
      }

      .contact-links {
        display: flex;
        justify-content: center;
        gap: 2rem;
        margin-top: 1rem;
      }

      footer {
        text-align: center;
        padding: 3rem 2rem;
        font-size: 0.85rem;
        color: #64748b;
      }
    </style>
  </head>
  <body>
    <header>
      <h1>samhith's corner</h1>
      <p>doing whatever inspires me to break as many things as possible.</p>
    </header>

    <main style="padding: 0 1rem;">
      <section class="section-content">
        <h2>About Me</h2>
        <p style="margin: 0 auto; max-width: 600px;">
          Hi, I'm Samhith. I'm a {age} year old developer in the Bay Area who likes to code and make projects for the fun of it.
          When I'm not coding, you can find me playing guitar or exploring the outdoors.
          I'm part of <a href="https://hackclub.com" target="_blank">Hack Club</a>, a global community of high school hackers - you should check it out!
        </p>
      </section>

      <section class="carousel-container">
        <h2 style="text-align: center;">Featured Projects</h2>
        <div class="carousel">
          <div class="carousel-inner">
            {[...data, ...data].map((project, index) => (
              <div class="card" key={index}>
                <div>
                  <h3><a href={project.link} target="_blank">{project.name}</a></h3>
                  <p>{project.description}</p>
                </div>
                <div class="tech-stack">
                  {project.tech.map(t => <span class="tech-tag">{t}</span>)}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section class="section-content">
        <h2>Get in Touch</h2>
        <p>Interested in collaborating or just want to say hi?</p>
        <div class="contact-links">
          <a href="mailto:your-email@example.com">Email</a>
          <a href="https://github.com/samhithpola" target="_blank">GitHub</a>
        </div>
      </section>
    </main>

    <footer>
      &copy; {currentYear} Samhith.
    </footer>
  </body>
</html>